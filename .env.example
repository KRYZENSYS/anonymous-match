# ===== App =====
APP_NAME=AnonymousMatch
APP_ENV=production
APP_DEBUG=false
APP_URL=https://yourdomain.com
API_URL=https://api.yourdomain.com
WEBAPP_URL=https://yourdomain.com

# ===== Bot =====
# @BotFather → /newbot → copy token
BOT_TOKEN=1234567890:AAH_your_token_here
BOT_USERNAME=YourAnonymousMatchBot
# Bot uchun webhook (ixtiyoriy, hozircha polling ishlaydi)
BOT_WEBHOOK_URL=
BOT_WEBHOOK_SECRET=

# ===== Database (PostgreSQL) =====
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=kryzen
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=anonymous_match
DATABASE_URL=postgresql+asyncpg://kryzen:change_me_strong_password@postgres:5432/anonymous_match

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# ===== Security =====
# openssl rand -hex 32
JWT_SECRET=change_me_use_64_chars_random_hex_string_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_HOURS=720
COOKIE_SECRET=change_me_another_random_string_for_cookies
CSRF_SECRET=change_me_csrf_secret_32_chars
BCRYPT_ROUNDS=12

# ===== Admin =====
# Birinchi adminlar (vergul bilan ajratilgan Telegram ID'lar)
ADMIN_TELEGRAM_IDS=123456789,987654321

# ===== Storage (Cloudinary) =====
# Ixtiyoriy — bo'lmasa local file storage ishlatiladi
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=

# ===== Premium =====
PREMIUM_PRICE_STARS=500                # Telegram Stars narx
SUPERLIKE_DAILY_FREE=1
LIKES_DAILY_FREE=50
BOOST_DURATION_MINUTES=30

# ===== Match / Discover =====
SWIPE_DAILY_LIMIT=100
SUPERLIKE_WEEKLY_LIMIT=5

# ===== Rate Limit =====
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
FLOOD_WINDOW_SECONDS=10
FLOOD_MAX_MESSAGES=5

# ===== Logging =====
LOG_LEVEL=INFO
LOG_FILE=/var/log/anonymous-match/app.log

# ===== Sentry (ixtiyoriy) =====
SENTRY_DSN=
